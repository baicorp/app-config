  "agent": {
    "default_model": {
      "provider": "google",
      "model": "gemini-2.5-flash"
    },
    "model_parameters": []
  },
  "disable_ai": false,
  "ui_font_size": 19,
  "ui_font_family": "JetBrains Mono",
  "buffer_font_size": 17,
  "buffer_font_family": "JetBrains Mono",
  "terminal": {
    "font_size": 15,
    "dock": "left",
  },
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "One Dark Pro Max",
  },
  "icon_theme": "Material Icon Theme",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "tab_bar": {
    "show": false,
  },
  "project_panel": {
    "dock": "right",
    "indent_guides": {
      "show": "never",
    },
    "indent_size": 14,
  },
  "indent_guides": {
    // disabled indent guide line in editor
    "enabled": false,
  },
}

